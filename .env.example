# =============================================================================
# Local secrets for development
# -----------------------------------------------------------------------------
# 1. Copy this file to `local.env` (gitignored):
#      cp .env.example local.env
# 2. Replace every placeholder below with your own keys.
# 3. Never commit `local.env` or paste real secrets into `.env.example`.
#
# Vite loads `local.env` on the dev server only (see vite.config.js).
# =============================================================================

# --- Mux (live streams, VOD assets, HLS for Overshoot bridge) ---------------
# Dashboard → Settings → Access Tokens:
#   https://dashboard.mux.com/settings/access-tokens
# Create a token with permission to manage Video (live streams, assets).
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret

# --- Overshoot (real-time vision / chat on video) ----------------------------
# Sign up and create an API key (format ovs_...):
#   https://overshoot.ai
# The dev server proxies /api/overshoot/* so this key stays off the client bundle.
# Do NOT add a VITE_ prefix — that would expose the key in the browser build.
OVERSHOOT_API_KEY=ovs_your_api_key_here

# --- Optional: FFmpeg macOS camera → Mux ------------------------------------
# After you create a live stream in the app, paste the **stream key** here so
# `npm run stream:camera` can read it from the environment (see README).
# Keep this secret — it allows publishing to your Mux live stream.
MUX_STREAM_KEY=

# --- fal.ai (Lucy VTON realtime on /camera) --------------------------------
# Dashboard → API Keys:
#   https://fal.ai/dashboard
# You can set this here OR as VITE_FAL_KEY in `.env` / `.env.local` (also merged by Vite).
VITE_FAL_KEY=your_fal_api_key
